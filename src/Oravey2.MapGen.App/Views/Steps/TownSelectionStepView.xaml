<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Oravey2.MapGen.ViewModels;assembly=Oravey2.MapGen"
             x:Class="Oravey2.MapGen.App.Views.TownSelectionStepView"
             x:DataType="vm:TownSelectionStepViewModel">
    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="8">
            <Label Text="④ Town Selection" FontSize="24" FontAttributes="Bold" />
            <Label Text="Use LLM to select or discover towns for the region."
                   TextColor="#AAAAAA" />

            <!-- Mode Toggle -->
            <Border Stroke="#444444" StrokeThickness="1" Padding="12,8" BackgroundColor="#252530">
                <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label Text="Mode" FontSize="15" FontAttributes="Bold" TextColor="White" />
                    <HorizontalStackLayout Spacing="16">
                        <RadioButton Content="A — Discover"
                                     IsChecked="{Binding IsModeA}" GroupName="Mode"
                                     TextColor="White" />
                        <RadioButton Content="B — Select from list"
                                     IsChecked="{Binding IsModeB}" GroupName="Mode"
                                     TextColor="White" />
                    </HorizontalStackLayout>
                    <Label Text="{Binding ModeDescription}" TextColor="#888888" FontSize="12" />

                    <HorizontalStackLayout Spacing="8">
                        <Label Text="Seed:" VerticalOptions="Center" TextColor="White" />
                        <Entry Text="{Binding Seed}" Keyboard="Numeric" WidthRequest="80" TextColor="White" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Action Buttons -->
            <HorizontalStackLayout Spacing="8">
                <Button Text="Run LLM"
                        Command="{Binding RunLlmCommand}"
                        BackgroundColor="#238636" TextColor="White"
                        Padding="16,8" />
                <Button Text="Re-roll All"
                        Command="{Binding RerollAllCommand}"
                        BackgroundColor="#2D2D30" TextColor="White"
                        Padding="12,6" />
                <Button Text="Add Town"
                        Command="{Binding AddTownCommand}"
                        BackgroundColor="#2D2D30" TextColor="White"
                        Padding="12,6" />
                <Button Text="Cancel"
                        Command="{Binding CancelCommand}"
                        BackgroundColor="#6E3630" TextColor="White"
                        Padding="12,6"
                        IsVisible="{Binding IsRunning}" />
                <ActivityIndicator IsRunning="{Binding IsRunning}" IsVisible="{Binding IsRunning}"
                                   Color="#0078D4" HeightRequest="24" WidthRequest="24" />
            </HorizontalStackLayout>

            <Label Text="{Binding StatusText}" TextColor="#888888" FontSize="13" />

            <!-- Validation Panel -->
            <Border IsVisible="{Binding HasResults}"
                    Stroke="#444444" StrokeThickness="1" Padding="12,8" BackgroundColor="#252530">
                <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                <Label Text="{Binding ValidationSummary}" FontSize="14" TextColor="White" />
            </Border>

            <!-- Town Cards -->
            <CollectionView ItemsSource="{Binding Towns}"
                            IsVisible="{Binding HasResults}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:TownSelectionItem">
                        <Border Stroke="#444444" StrokeThickness="1" Padding="12" BackgroundColor="#1E1E1E">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                                <!-- Include checkbox -->
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsIncluded}" VerticalOptions="Start" />

                                <!-- Display mode (not editing) -->
                                <VerticalStackLayout Grid.Column="1" IsVisible="{Binding IsNotEditing}" Spacing="2">
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding GameName}" FontSize="16" FontAttributes="Bold" TextColor="White" />
                                        <Label Text="{Binding RealName, StringFormat='({0})'}" FontSize="13" TextColor="#888888" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="12">
                                        <Label Text="{Binding Role}" FontSize="12" TextColor="#AAAAAA" />
                                        <Label Text="{Binding Faction}" FontSize="12" TextColor="#AAAAAA" />
                                        <Label Text="{Binding ThreatLevel, StringFormat='Threat: {0}'}" FontSize="12" TextColor="{Binding ThreatColor}" FontAttributes="Bold" />
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding Description}" FontSize="12" TextColor="#CCCCCC" />
                                </VerticalStackLayout>

                                <!-- Edit mode -->
                                <VerticalStackLayout Grid.Column="1" IsVisible="{Binding IsEditing}" Spacing="4">
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="Game Name:" VerticalOptions="Center" TextColor="White" WidthRequest="90" />
                                        <Entry Text="{Binding GameName}" WidthRequest="200" TextColor="White" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="Real Name:" VerticalOptions="Center" TextColor="White" WidthRequest="90" />
                                        <Entry Text="{Binding RealName}" WidthRequest="200" TextColor="White" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="Role:" VerticalOptions="Center" TextColor="White" WidthRequest="90" />
                                        <Entry Text="{Binding Role}" WidthRequest="200" TextColor="White" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="Faction:" VerticalOptions="Center" TextColor="White" WidthRequest="90" />
                                        <Entry Text="{Binding Faction}" WidthRequest="200" TextColor="White" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="Threat (1-10):" VerticalOptions="Center" TextColor="White" WidthRequest="90" />
                                        <Entry Text="{Binding ThreatLevel}" Keyboard="Numeric" WidthRequest="60" TextColor="White" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="Lat / Lon:" VerticalOptions="Center" TextColor="White" WidthRequest="90" />
                                        <Entry Text="{Binding Latitude}" Keyboard="Numeric" WidthRequest="90" TextColor="White" />
                                        <Entry Text="{Binding Longitude}" Keyboard="Numeric" WidthRequest="90" TextColor="White" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="Description:" VerticalOptions="Center" TextColor="White" WidthRequest="90" />
                                        <Entry Text="{Binding Description}" WidthRequest="350" TextColor="White" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <!-- Action buttons -->
                                <HorizontalStackLayout Grid.Column="2" Spacing="4" VerticalOptions="Start">
                                    <Button Text="Edit"
                                            Clicked="OnEditToggle"
                                            BackgroundColor="#2D2D30" TextColor="White"
                                            Padding="8,4" FontSize="11" />
                                    <Button Text="Re-roll"
                                            Clicked="OnReroll"
                                            BackgroundColor="#2D2D30" TextColor="White"
                                            Padding="8,4" FontSize="11" />
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- LLM Log -->
            <Label Text="LLM Log" FontAttributes="Bold" TextColor="White"
                   IsVisible="{Binding HasResults}" Margin="0,12,0,0" />
            <CollectionView ItemsSource="{Binding LlmLog}"
                            IsVisible="{Binding HasResults}"
                            MaximumHeightRequest="300">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="4" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:LlmLogEntry">
                        <Border Stroke="#333333" StrokeThickness="1" Padding="8" BackgroundColor="#1A1A2E">
                            <Border.StrokeShape><RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                            <VerticalStackLayout Spacing="2">
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="{Binding Direction}" FontAttributes="Bold"
                                           TextColor="#0078D4" FontSize="12" />
                                    <Label Text="{Binding Timestamp, StringFormat='{0:HH:mm:ss}'}"
                                           TextColor="#666666" FontSize="11" />
                                </HorizontalStackLayout>
                                <Label Text="{Binding Content}" FontSize="11"
                                       FontFamily="Consolas" TextColor="#CCCCCC"
                                       LineBreakMode="WordWrap" MaxLines="20" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Save & Next -->
            <Button Text="Save &amp; Next →"
                    Command="{Binding SaveNextCommand}"
                    HorizontalOptions="Start"
                    BackgroundColor="#0078D4"
                    TextColor="White"
                    Margin="0,16,0,0" />
        </VerticalStackLayout>
    </ScrollView>
</ContentView>
