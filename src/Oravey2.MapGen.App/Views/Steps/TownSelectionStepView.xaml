<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Oravey2.MapGen.ViewModels;assembly=Oravey2.MapGen"
             x:Class="Oravey2.MapGen.App.Views.TownSelectionStepView"
             x:DataType="vm:TownSelectionStepViewModel">
    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="8">
            <Label Text="④ Town Selection" Style="{StaticResource HeaderLabel}" />
            <Label Text="Use LLM to select or discover towns for the region."
                   TextColor="{StaticResource OnSurfaceVariant}" />
            <Button AutomationId="TownSelectionSaveNextButton"
                    Text="Save &amp; Next →"
                    Command="{Binding SaveNextCommand}"
                    HorizontalOptions="Start"
                    Style="{StaticResource PrimaryButton}" />

            <!-- Mode Toggle -->
            <Border Style="{StaticResource CardBorder}" Padding="12,8">
                <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label Text="Mode" FontSize="15" FontAttributes="Bold" />
                    <HorizontalStackLayout Spacing="16">
                        <RadioButton Content="A — Discover"
                                     IsChecked="{Binding IsModeA}" GroupName="Mode" />
                        <RadioButton Content="B — Select from list"
                                     IsChecked="{Binding IsModeB}" GroupName="Mode" />
                    </HorizontalStackLayout>
                    <Label Text="{Binding ModeDescription}" TextColor="{StaticResource OnSurfaceVariant}" FontSize="12" />
                </VerticalStackLayout>
            </Border>

            <!-- Min/Max Towns -->
            <HorizontalStackLayout Spacing="12">
                <Label Text="Min Towns:" VerticalOptions="Center" />
                <Entry AutomationId="TownSelectionMinTowns"
                       Text="{Binding MinTowns}" Keyboard="Numeric" WidthRequest="60" />
                <Label Text="Max Towns:" VerticalOptions="Center" />
                <Entry AutomationId="TownSelectionMaxTowns"
                       Text="{Binding MaxTowns}" Keyboard="Numeric" WidthRequest="60" />
            </HorizontalStackLayout>

            <!-- Action Buttons -->
            <HorizontalStackLayout Spacing="8">
                <Button AutomationId="TownSelectionRunLlmButton"
                        Text="Run LLM"
                        Command="{Binding RunLlmCommand}"
                        Style="{StaticResource SuccessButton}"
                        Padding="16,8" />
                <Button AutomationId="TownSelectionRerollAllButton"
                        Text="Re-roll All"
                        Command="{Binding RerollAllCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Padding="12,6" />
                <Button AutomationId="TownSelectionAddTownButton"
                        Text="Add Town"
                        Clicked="OnAddTown"
                        Style="{StaticResource SecondaryButton}"
                        Padding="12,6" />
                <Button AutomationId="TownSelectionCancelButton"
                        Text="Cancel"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource DangerButton}"
                        Padding="12,6"
                        IsVisible="{Binding IsRunning}" />
                <ActivityIndicator IsRunning="{Binding IsRunning}" IsVisible="{Binding IsRunning}"
                                    HeightRequest="24" WidthRequest="24" />
            </HorizontalStackLayout>

            <Label AutomationId="TownSelectionStatusText"
                   Text="{Binding StatusText}" TextColor="{StaticResource OnSurfaceVariant}" FontSize="13" />

            <!-- Validation Panel -->
            <Border IsVisible="{Binding HasResults}"
                    Style="{StaticResource CardBorder}" Padding="12,8">
                <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                <Label AutomationId="TownSelectionValidationSummary"
                       Text="{Binding ValidationSummary}" FontSize="14" />
            </Border>

            <!-- Search & Sort -->
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8"
                  IsVisible="{Binding HasResults}">
                <Entry AutomationId="TownSelectionSearchEntry"
                       Placeholder="Search by name..."
                       Text="{Binding SearchText}"
                       ClearButtonVisibility="WhileEditing" />
                <HorizontalStackLayout Grid.Column="1" Spacing="4">
                    <Button AutomationId="TownSelectionSortNameButton"
                            Text="Name ↕"
                            Clicked="OnSortByName"
                            Style="{StaticResource SecondaryButton}"
                            Padding="8,4" FontSize="11" />
                    <Button AutomationId="TownSelectionSortSizeButton"
                            Text="Size ↕"
                            Clicked="OnSortBySize"
                            Style="{StaticResource SecondaryButton}"
                            Padding="8,4" FontSize="11" />
                </HorizontalStackLayout>
            </Grid>

            <!-- Tab Bar -->
            <HorizontalStackLayout Spacing="0" IsVisible="{Binding HasResults}">
                <Button x:Name="ListTabBtn" AutomationId="TownSelectionListTab"
                        Text="📋 List" Clicked="OnListTab"
                        Style="{StaticResource PrimaryButton}"
                        Padding="16,8" FontSize="13" />
                <Button x:Name="MapTabBtn" AutomationId="TownSelectionMapTab"
                        Text="🗺 Map" Clicked="OnMapTab"
                        Style="{StaticResource SecondaryButton}"
                        Padding="16,8" FontSize="13" />
            </HorizontalStackLayout>

            <!-- Town Cards (List Tab) -->
            <CollectionView ItemsSource="{Binding FilteredTowns}"
                            IsVisible="{Binding IsListTabVisible}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:TownSelectionItem">
                        <Border Style="{StaticResource CardBorder}" Padding="12">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                                <!-- Include checkbox -->
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsIncluded}" VerticalOptions="Start" />

                                <!-- Display mode (not editing) -->
                                <VerticalStackLayout Grid.Column="1" IsVisible="{Binding IsNotEditing}" Spacing="2">
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding GameName}" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource OnSurface}" />
                                        <Label Text="{Binding RealName, StringFormat='({0})'}" FontSize="13" TextColor="{StaticResource OnSurfaceVariant}" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding Description}" FontSize="12" TextColor="{StaticResource OnSurface}" />
                                    <HorizontalStackLayout Spacing="12">
                                        <Label Text="{Binding Size, StringFormat='Size: {0}'}" FontSize="12" TextColor="{StaticResource OnSurfaceVariant}" />
                                        <Label Text="{Binding Inhabitants, StringFormat='Pop: {0:N0}'}" FontSize="12" TextColor="{StaticResource OnSurfaceVariant}" />
                                        <Label Text="{Binding Destruction, StringFormat='Destruction: {0}'}" FontSize="12" TextColor="{Binding DestructionColor}" FontAttributes="Bold" />
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding Latitude, StringFormat='Lat: {0:F4}'}" FontSize="11" TextColor="{StaticResource OnSurfaceVariant}" />
                                    <Label Text="{Binding Longitude, StringFormat='Lon: {0:F4}'}" FontSize="11" TextColor="{StaticResource OnSurfaceVariant}" />
                                </VerticalStackLayout>

                                <!-- Edit mode -->
                                <VerticalStackLayout Grid.Column="1" IsVisible="{Binding IsEditing}" Spacing="4">
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="Game Name:" VerticalOptions="Center" TextColor="{StaticResource OnSurface}" WidthRequest="90" />
                                        <Entry Text="{Binding GameName}" WidthRequest="200" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="Real Name:" VerticalOptions="Center" TextColor="{StaticResource OnSurface}" WidthRequest="90" />
                                        <Label Text="{Binding RealName}" TextColor="{StaticResource OnSurfaceVariant}" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="Description:" VerticalOptions="Center" TextColor="{StaticResource OnSurface}" WidthRequest="90" />
                                        <Entry Text="{Binding Description}" WidthRequest="350" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="Size:" VerticalOptions="Center" TextColor="{StaticResource OnSurface}" WidthRequest="90" />
                                        <Entry Text="{Binding Size}" WidthRequest="120" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="Inhabitants:" VerticalOptions="Center" TextColor="{StaticResource OnSurface}" WidthRequest="90" />
                                        <Entry Text="{Binding Inhabitants}" Keyboard="Numeric" WidthRequest="100" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="Destruction:" VerticalOptions="Center" TextColor="{StaticResource OnSurface}" WidthRequest="90" />
                                        <Entry Text="{Binding Destruction}" WidthRequest="120" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="Lat / Lon:" VerticalOptions="Center" TextColor="{StaticResource OnSurface}" WidthRequest="90" />
                                        <Label Text="{Binding Latitude, StringFormat='{0:F4}'}" TextColor="{StaticResource OnSurfaceVariant}" VerticalOptions="Center" />
                                        <Label Text="{Binding Longitude, StringFormat='{0:F4}'}" TextColor="{StaticResource OnSurfaceVariant}" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <!-- Action buttons -->
                                <VerticalStackLayout Grid.Column="2" Spacing="4" VerticalOptions="Start">
                                    <Button Text="Edit"
                                            Clicked="OnEditToggle"
                                            Style="{StaticResource SecondaryButton}"
                                            Padding="8,4" FontSize="11" />
                                    <Button Text="Re-roll"
                                            Clicked="OnReroll"
                                            Style="{StaticResource SecondaryButton}"
                                            Padding="8,4" FontSize="11" />
                                    <Button Text="Delete"
                                            Clicked="OnDeleteTown"
                                            Style="{StaticResource DangerButton}"
                                            Padding="8,4" FontSize="11" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Map Tab -->
            <Border IsVisible="{Binding IsMapTabVisible}"
                    Style="{StaticResource CardBorder}"
                    HeightRequest="500" Padding="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                <GraphicsView x:Name="MapCanvas"
                              AutomationId="TownSelectionMapCanvas"
                              HeightRequest="500" />
            </Border>

            <!-- LLM Log -->
            <Label Text="LLM Log" FontAttributes="Bold"
                   IsVisible="{Binding HasResults}" Margin="0,12,0,0" />
            <CollectionView ItemsSource="{Binding LlmLog}"
                            IsVisible="{Binding HasResults}"
                            MaximumHeightRequest="300">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="4" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:LlmLogEntry">
                        <Border Style="{StaticResource CardBorder}" Padding="8">
                            <Border.StrokeShape><RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                            <VerticalStackLayout Spacing="2">
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="{Binding Direction}" FontAttributes="Bold"
                                           TextColor="{StaticResource ActionBlue}" FontSize="12" />
                                    <Label Text="{Binding Timestamp, StringFormat='{0:HH:mm:ss}'}"
                                           TextColor="{StaticResource OnSurfaceVariant}" FontSize="11" />
                                </HorizontalStackLayout>
                                <Label Text="{Binding Content}" FontSize="11"
                                       FontFamily="Consolas" TextColor="{StaticResource OnSurface}"
                                       LineBreakMode="WordWrap" MaxLines="20" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentView>
