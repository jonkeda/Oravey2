<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Oravey2.MapGen.ViewModels;assembly=Oravey2.MapGen"
             xmlns:gen="clr-namespace:Oravey2.MapGen.Generation;assembly=Oravey2.MapGen"
             x:Class="Oravey2.MapGen.App.Views.TownDesignStepView"
             x:DataType="vm:TownDesignStepViewModel">
    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="8">

            <!-- Header -->
            <Label Text="⑤ Town Design" Style="{StaticResource HeaderLabel}" />
            <Label Text="Use LLM to generate a design for each curated town."
                   TextColor="{StaticResource OnSurfaceVariant}" />
            <Button Text="Next →"
                    Command="{Binding NextCommand}"
                    HorizontalOptions="Start"
                    Style="{StaticResource PrimaryButton}" />

            <!-- Master–Detail Grid -->
            <Grid ColumnDefinitions="280,16,*" MinimumHeightRequest="500">

                <!-- LEFT COLUMN: Town list + actions -->
                <VerticalStackLayout Grid.Column="0" Spacing="8">

                    <!-- Town list -->
                    <CollectionView ItemsSource="{Binding Towns}"
                                    SelectedItem="{Binding SelectedTown}"
                                    SelectionMode="Single"
                                    HeightRequest="350">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="4" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:TownDesignItem">
                                <Border Style="{StaticResource CardBorder}" Padding="8,6">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding StatusIcon}" FontSize="14"
                                               VerticalOptions="Center" WidthRequest="24" TextColor="{StaticResource OnSurface}" />
                                        <VerticalStackLayout Spacing="1">
                                            <Label Text="{Binding GameName}" FontSize="14"
                                                   FontAttributes="Bold" TextColor="{StaticResource OnSurface}" />
                                            <Label Text="{Binding RealName, StringFormat='({0})'}"
                                                   FontSize="11" TextColor="{StaticResource OnSurfaceVariant}" />
                                        </VerticalStackLayout>
                                    </HorizontalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Progress -->
                    <Label Text="{Binding ProgressText}" TextColor="{StaticResource OnSurfaceVariant}" FontSize="13" />
                    <Label AutomationId="TownDesignIncompleteWarning"
                           Text="{Binding IncompleteWarning}"
                           IsVisible="{Binding HasIncompleteWarning}"
                           TextColor="{StaticResource Error}" FontSize="13" />

                    <!-- Action buttons -->
                    <Button Text="Design Town"
                            Command="{Binding DesignTownCommand}"
                            Style="{StaticResource SuccessButton}"
                            Padding="16,8" />
                    <Button Text="Design All Remaining"
                            Command="{Binding DesignAllCommand}"
                            BackgroundColor="{StaticResource SurfaceVariant}" 
                            Padding="12,6" />
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="Cancel"
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource DangerButton}"
                                Padding="12,6"
                                IsVisible="{Binding IsRunning}" />
                        <ActivityIndicator IsRunning="{Binding IsRunning}"
                                           IsVisible="{Binding IsRunning}"
                                            HeightRequest="24" WidthRequest="24" />
                    </HorizontalStackLayout>

                    <Label Text="{Binding StatusText}" TextColor="{StaticResource OnSurfaceVariant}" FontSize="13" />
                </VerticalStackLayout>

                <!-- RIGHT COLUMN: Design detail -->
                <ScrollView Grid.Column="2" IsVisible="{Binding HasSelection}">
                    <VerticalStackLayout Spacing="12"
                                         BindingContext="{Binding SelectedTown}"
                                         x:DataType="vm:TownDesignItem">

                        <!-- Town Summary Card -->
                        <Border Style="{StaticResource CardBorder}" Padding="12">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding GameName}" FontSize="18"
                                       FontAttributes="Bold" TextColor="{StaticResource OnSurface}" />
                                <HorizontalStackLayout Spacing="12">
                                    <Label Text="{Binding Role}" FontSize="13" TextColor="{StaticResource OnSurfaceVariant}" />
                                    <Label Text="{Binding Faction}" FontSize="13" TextColor="{StaticResource OnSurfaceVariant}" />
                                    <Label Text="{Binding ThreatLevel, StringFormat='Threat: {0}'}"
                                           FontSize="13" TextColor="{StaticResource Warning}" FontAttributes="Bold" />
                                </HorizontalStackLayout>
                                <Label Text="{Binding Description}" FontSize="12"
                                        TextColor="{StaticResource OnSurface}" LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Landmarks Card -->
                        <Border Style="{StaticResource CardBorder}" Padding="12"
                                IsVisible="{Binding Design, Converter={StaticResource IsNotNullConverter}}">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <VerticalStackLayout Spacing="6">
                                <Label FontSize="15" FontAttributes="Bold">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="🏛 Landmarks (" TextColor="{StaticResource OnSurface}" />
                                            <Span Text="{Binding LandmarkCount}" TextColor="{StaticResource OnSurface}" />
                                            <Span Text=")" TextColor="{StaticResource OnSurface}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <CollectionView ItemsSource="{Binding Design.Landmarks}">
                                    <CollectionView.ItemsLayout>
                                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="6" />
                                    </CollectionView.ItemsLayout>
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="gen:LandmarkBuilding">
                                            <VerticalStackLayout Spacing="2" Padding="0,2">
                                                <HorizontalStackLayout Spacing="8">
                                                    <Label Text="{Binding Name}" FontSize="14"
                                                           FontAttributes="Bold" TextColor="{StaticResource OnSurface}" />
                                                    <Border Padding="4,2" BackgroundColor="{StaticResource SurfaceVariant}">
                                                        <Border.StrokeShape><RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                                                        <Label Text="{Binding SizeCategory}"
                                                               FontSize="11" TextColor="{StaticResource OnSurfaceVariant}" />
                                                    </Border>
                                                </HorizontalStackLayout>
                                                <Label Text="{Binding OriginalDescription}" FontSize="11"
                                                       TextColor="{StaticResource OnSurfaceVariant}" LineBreakMode="WordWrap" />
                                                <Label Text="{Binding VisualDescription}" FontSize="11"
                                                       TextColor="{StaticResource OnSurface}" FontAttributes="Italic" LineBreakMode="WordWrap" />
                                                <Label Text="{Binding PositionHint, StringFormat='Position: {0}'}" FontSize="10"
                                                       TextColor="{StaticResource OnSurfaceVariant}" />
                                                <Label Text="{Binding MeshyPrompt, StringFormat='Meshy: {0}'}" FontSize="10"
                                                       TextColor="{StaticResource OnSurfaceVariant}" LineBreakMode="WordWrap" />
                                            </VerticalStackLayout>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Key Locations Card -->
                        <Border Style="{StaticResource CardBorder}" Padding="12"
                                IsVisible="{Binding Design, Converter={StaticResource IsNotNullConverter}}">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <VerticalStackLayout Spacing="6">
                                <Label FontSize="15" FontAttributes="Bold" >
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="📍 Key Locations (" TextColor="{StaticResource OnSurface}" />
                                            <Span Text="{Binding KeyLocationCount}" TextColor="{StaticResource OnSurface}" />
                                            <Span Text=")" TextColor="{StaticResource OnSurface}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <CollectionView ItemsSource="{Binding Design.KeyLocations}">
                                    <CollectionView.ItemsLayout>
                                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="6" />
                                    </CollectionView.ItemsLayout>
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="gen:KeyLocation">
                                            <VerticalStackLayout Spacing="2" Padding="0,2">
                                                <HorizontalStackLayout Spacing="8">
                                                    <Label Text="{Binding Name}" FontSize="13"
                                                           FontAttributes="Bold" TextColor="{StaticResource OnSurface}" />
                                                    <Label Text="{Binding Purpose}" FontSize="12"
                                                           TextColor="{StaticResource OnSurfaceVariant}" />
                                                    <Border Padding="4,1" BackgroundColor="{StaticResource SurfaceVariant}">
                                                        <Border.StrokeShape><RoundRectangle CornerRadius="3" /></Border.StrokeShape>
                                                        <Label Text="{Binding SizeCategory}"
                                                               FontSize="10" TextColor="{StaticResource OnSurfaceVariant}" />
                                                    </Border>
                                                </HorizontalStackLayout>
                                                <Label Text="{Binding OriginalDescription}" FontSize="10"
                                                       TextColor="{StaticResource OnSurfaceVariant}" LineBreakMode="WordWrap" />
                                                <Label Text="{Binding VisualDescription}"
                                                       FontSize="11" TextColor="{StaticResource OnSurface}"
                                                       LineBreakMode="WordWrap" />
                                                <Label Text="{Binding PositionHint, StringFormat='Position: {0}'}" FontSize="10"
                                                       TextColor="{StaticResource OnSurfaceVariant}" />
                                                <Label Text="{Binding MeshyPrompt, StringFormat='Meshy: {0}'}" FontSize="10"
                                                       TextColor="{StaticResource OnSurfaceVariant}" LineBreakMode="WordWrap" />
                                            </VerticalStackLayout>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Layout Style Badge -->
                        <HorizontalStackLayout Spacing="8"
                                               IsVisible="{Binding Design, Converter={StaticResource IsNotNullConverter}}">
                            <Label Text="Layout:" FontSize="14" TextColor="{StaticResource OnSurface}"
                                   VerticalOptions="Center" />
                            <Border Padding="8,4" BackgroundColor="{StaticResource Success}"
                                    Stroke="{StaticResource Success}" StrokeThickness="0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                <Label Text="{Binding LayoutStyle}" FontSize="13"
                                       TextColor="{StaticResource OnSuccess}" FontAttributes="Bold" />
                            </Border>
                        </HorizontalStackLayout>

                        <!-- Hazards Card -->
                        <Border Style="{StaticResource CardBorder}" Padding="12"
                                IsVisible="{Binding Design, Converter={StaticResource IsNotNullConverter}}">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <VerticalStackLayout Spacing="6">
                                <Label FontSize="15" FontAttributes="Bold" >
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="⚠ Hazards (" TextColor="{StaticResource OnSurface}" />
                                            <Span Text="{Binding HazardCount}" TextColor="{StaticResource OnSurface}" />
                                            <Span Text=")" TextColor="{StaticResource OnSurface}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <CollectionView ItemsSource="{Binding Design.Hazards}">
                                    <CollectionView.ItemsLayout>
                                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="6" />
                                    </CollectionView.ItemsLayout>
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="gen:EnvironmentalHazard">
                                            <VerticalStackLayout Spacing="2" Padding="0,2">
                                                <HorizontalStackLayout Spacing="8">
                                                    <Label Text="{Binding Type}" FontSize="13"
                                                           FontAttributes="Bold" TextColor="{StaticResource Warning}" />
                                                    <Label Text="{Binding LocationHint}" FontSize="12"
                                                           TextColor="{StaticResource OnSurfaceVariant}" />
                                                </HorizontalStackLayout>
                                                <Label Text="{Binding Description}"
                                                       FontSize="11" TextColor="{StaticResource OnSurface}"
                                                       LineBreakMode="WordWrap" />
                                            </VerticalStackLayout>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Detail Action Buttons -->
                        <HorizontalStackLayout Spacing="8">
                            <Button Text="Accept"
                                    Command="{Binding AcceptCommand, Source={RelativeSource AncestorType={x:Type vm:TownDesignStepViewModel}}}"
                                    Style="{StaticResource SuccessButton}"
                                    Padding="12,6" />
                            <Button Text="Re-generate"
                                    Command="{Binding RegenerateCommand, Source={RelativeSource AncestorType={x:Type vm:TownDesignStepViewModel}}}"
                                    BackgroundColor="{StaticResource SurfaceVariant}" 
                                    Padding="12,6" />
                        </HorizontalStackLayout>

                    </VerticalStackLayout>
                </ScrollView>
            </Grid>

            <!-- LLM Log -->
            <Label Text="LLM Log" FontAttributes="Bold"  Margin="0,12,0,0" />
            <CollectionView ItemsSource="{Binding LlmLog}"
                            MaximumHeightRequest="250">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="4" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:LlmLogEntry">
                        <Border Style="{StaticResource CardBorder}" Padding="8">
                            <Border.StrokeShape><RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                            <VerticalStackLayout Spacing="2">
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="{Binding Direction}" FontAttributes="Bold"
                                           TextColor="{StaticResource ActionBlue}" FontSize="12" />
                                    <Label Text="{Binding Timestamp, StringFormat='{0:HH:mm:ss}'}"
                                           TextColor="{StaticResource OnSurfaceVariant}" FontSize="11" />
                                </HorizontalStackLayout>
                                <Label Text="{Binding Content}" FontSize="11"
                                       FontFamily="Consolas" TextColor="{StaticResource OnSurface}"
                                       LineBreakMode="WordWrap" MaxLines="20" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>


        </VerticalStackLayout>
    </ScrollView>
</ContentView>
