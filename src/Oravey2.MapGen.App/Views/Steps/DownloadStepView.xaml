<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Oravey2.MapGen.ViewModels;assembly=Oravey2.MapGen"
             x:Class="Oravey2.MapGen.App.Views.DownloadStepView"
             x:DataType="vm:DownloadStepViewModel">
    <VerticalStackLayout Spacing="16" Padding="8">
        <Label Text="② Download Data" Style="{StaticResource HeaderLabel}" />
        <Label Text="Download SRTM elevation tiles and OpenStreetMap PBF extract for the selected region."
               TextColor="{StaticResource OnSurfaceVariant}" />
        <Button Text="Next →"
                Command="{Binding NextCommand}"
                HorizontalOptions="Start"
                Style="{StaticResource PrimaryButton}" />

        <!-- Two side-by-side cards -->
        <Grid ColumnDefinitions="*,16,*" Margin="0,8,0,0">

            <!-- SRTM Card -->
            <Border Grid.Column="0"
                    Style="{StaticResource CardBorder}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label Text="SRTM Elevation Data" Style="{StaticResource SectionLabel}" />
                    <Label Text="{Binding SrtmCountText}" TextColor="{StaticResource OnSurfaceVariant}" FontSize="13" />
                    <Label Text="{Binding SrtmStatusText}" FontSize="13" />
                    <ProgressBar Progress="{Binding SrtmProgress}" />
                    <Button Text="Download SRTM"
                            Command="{Binding DownloadSrtmCommand}"
                            HorizontalOptions="Start"
                            Style="{StaticResource SecondaryButton}" />
                </VerticalStackLayout>
            </Border>

            <!-- OSM Card -->
            <Border Grid.Column="2"
                    Style="{StaticResource CardBorder}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label Text="OpenStreetMap Extract" Style="{StaticResource SectionLabel}" />
                    <Label Text="{Binding OsmFileName}" TextColor="{StaticResource OnSurfaceVariant}" FontSize="13" />
                    <Label Text="{Binding OsmStatusText}" FontSize="13" />
                    <ProgressBar Progress="{Binding OsmProgress}" />
                    <Button Text="Download OSM"
                            Command="{Binding DownloadOsmCommand}"
                            HorizontalOptions="Start"
                            Style="{StaticResource SecondaryButton}" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Cancel Button (visible during download) -->
        <Button Text="Cancel Download"
                Command="{Binding CancelCommand}"
                IsVisible="{Binding IsDownloading}"
                HorizontalOptions="Start"
                Style="{StaticResource DangerButton}" />


    </VerticalStackLayout>
</ContentView>
