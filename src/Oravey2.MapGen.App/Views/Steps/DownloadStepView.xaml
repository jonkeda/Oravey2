<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Oravey2.MapGen.ViewModels;assembly=Oravey2.MapGen"
             x:Class="Oravey2.MapGen.App.Views.DownloadStepView"
             x:DataType="vm:DownloadStepViewModel">
    <VerticalStackLayout Spacing="16" Padding="8">
        <Label Text="② Download Data" FontSize="24" FontAttributes="Bold" />
        <Label Text="Download SRTM elevation tiles and OpenStreetMap PBF extract for the selected region."
               TextColor="#AAAAAA" />

        <!-- Two side-by-side cards -->
        <Grid ColumnDefinitions="*,16,*" Margin="0,8,0,0">

            <!-- SRTM Card -->
            <Border Grid.Column="0"
                    Stroke="#444444"
                    StrokeThickness="1"
                    Padding="16"
                    BackgroundColor="#1E1E1E">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label Text="SRTM Elevation Data" FontSize="16" FontAttributes="Bold" />
                    <Label Text="{Binding SrtmCountText}" TextColor="#AAAAAA" FontSize="13" />
                    <Label Text="{Binding SrtmStatusText}" FontSize="13" />
                    <ProgressBar Progress="{Binding SrtmProgress}" ProgressColor="#0078D4" />
                    <Button Text="Download SRTM"
                            Command="{Binding DownloadSrtmCommand}"
                            HorizontalOptions="Start"
                            BackgroundColor="#2D2D30"
                            TextColor="White" />
                </VerticalStackLayout>
            </Border>

            <!-- OSM Card -->
            <Border Grid.Column="2"
                    Stroke="#444444"
                    StrokeThickness="1"
                    Padding="16"
                    BackgroundColor="#1E1E1E">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label Text="OpenStreetMap Extract" FontSize="16" FontAttributes="Bold" />
                    <Label Text="{Binding OsmFileName}" TextColor="#AAAAAA" FontSize="13" />
                    <Label Text="{Binding OsmStatusText}" FontSize="13" />
                    <ProgressBar Progress="{Binding OsmProgress}" ProgressColor="#0078D4" />
                    <Button Text="Download OSM"
                            Command="{Binding DownloadOsmCommand}"
                            HorizontalOptions="Start"
                            BackgroundColor="#2D2D30"
                            TextColor="White" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Cancel Button (visible during download) -->
        <Button Text="Cancel Download"
                Command="{Binding CancelCommand}"
                IsVisible="{Binding IsDownloading}"
                HorizontalOptions="Start"
                BackgroundColor="#D32F2F"
                TextColor="White" />

        <!-- Next Button -->
        <Button Text="Next →"
                Command="{Binding NextCommand}"
                HorizontalOptions="Start"
                BackgroundColor="#0078D4"
                TextColor="White"
                Margin="0,8,0,0" />
    </VerticalStackLayout>
</ContentView>
