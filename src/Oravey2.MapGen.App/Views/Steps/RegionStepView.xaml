<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Oravey2.MapGen.ViewModels;assembly=Oravey2.MapGen"
             x:Class="Oravey2.MapGen.App.Views.RegionStepView"
             x:DataType="vm:RegionStepViewModel">
    <VerticalStackLayout Spacing="16" Padding="8">
        <Label Text="① Content Pack" Style="{StaticResource HeaderLabel}" />
        <Label Text="Select an existing content pack or create a new one."
               TextColor="{StaticResource OnSurfaceVariant}" />

        <!-- Content Pack List -->
        <CollectionView AutomationId="ContentPackList"
                        ItemsSource="{Binding ContentPackInfos}"
                        SelectedItem="{Binding SelectedPackInfo, Mode=TwoWay}"
                        SelectionMode="Single"
                        HeightRequest="220">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:ContentPackInfo">
                    <Border Style="{StaticResource CardBorder}" Margin="0,4" Padding="12,8">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="2">
                            <Label Text="{Binding DirectoryName}" TextColor="{StaticResource OnSurface}"
                                   FontSize="15" FontAttributes="Bold" />
                            <Label Text="{Binding RegionCode}" TextColor="{StaticResource OnSurfaceVariant}"
                                   FontSize="12" />
                            <Label Text="{Binding Description}" TextColor="{StaticResource OnSurfaceVariant}"
                                   FontSize="12" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <Label Text="No content packs found. Create one to get started."
                       TextColor="{StaticResource OnSurfaceVariant}"
                       HorizontalTextAlignment="Center" Margin="0,20" />
            </CollectionView.EmptyView>
        </CollectionView>

        <!-- Create Content Pack -->
        <Button AutomationId="ContentPackCreateButton"
                Text="+ Create Content Pack"
                Command="{Binding CreateContentPackCommand}"
                HorizontalOptions="Start"
                Style="{StaticResource SecondaryButton}" />

        <!-- Selected Pack Card -->
        <Border IsVisible="{Binding HasSelectedPack}"
                Style="{StaticResource CardBorder}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8" />
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="4" Padding="12,8">
                <Label AutomationId="ContentPackSelectedName"
                       Text="{Binding SelectedPackInfo.DirectoryName}"
                       TextColor="{StaticResource OnSurface}"
                       FontSize="16" FontAttributes="Bold" />
                <Label AutomationId="ContentPackHierarchy"
                       Text="{Binding SelectedPackHierarchy}"
                       TextColor="{StaticResource OnSurfaceVariant}"
                       FontSize="12" />
            </VerticalStackLayout>
        </Border>

        <!-- Next -->
        <Button AutomationId="ContentPackNextButton"
                Text="Next →"
                Command="{Binding NextCommand}"
                HorizontalOptions="Start"
                Style="{StaticResource PrimaryButton}" />
    </VerticalStackLayout>
</ContentView>
