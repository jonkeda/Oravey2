<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Oravey2.MapGen.ViewModels;assembly=Oravey2.MapGen"
             xmlns:wt="clr-namespace:Oravey2.MapGen.ViewModels.RegionTemplate;assembly=Oravey2.MapGen"
             x:Class="Oravey2.MapGen.App.Views.RegionTemplateView"
             x:DataType="vm:RegionTemplateViewModel"
             Title="Region Template">

    <ScrollView Padding="16">
        <VerticalStackLayout Spacing="12">

            <!-- ═══ Region & Data Sources ═══ -->
            <Label Text="Region &amp; Data Sources" FontAttributes="Bold" FontSize="16" />

            <!-- Preset row -->
            <HorizontalStackLayout Spacing="8">
                <Label Text="Preset" VerticalOptions="Center" WidthRequest="80" />
                <Picker ItemsSource="{Binding Presets}"
                        SelectedItem="{Binding SelectedPreset}"
                        ItemDisplayBinding="{Binding DisplayName}"
                        WidthRequest="220" />
                <Button Text="Browse…" Clicked="OnBrowseRegion" Padding="8,4" />
                <Button Text="Save Preset…" Command="{Binding SavePresetCommand}" Padding="8,4" />
            </HorizontalStackLayout>

            <!-- SRTM row -->
            <HorizontalStackLayout Spacing="8">
                <Label Text="SRTM Dir" VerticalOptions="Center" WidthRequest="80" />
                <Entry Text="{Binding SrtmDirectory}" Placeholder="data/srtm" WidthRequest="300" />
                <Button Text="Browse" Clicked="OnBrowseSrtm" Padding="8,4" />
                <Button Text="⬇" Command="{Binding DownloadSrtmCommand}" Padding="8,4"
                        ToolTipProperties.Text="Download SRTM tiles" />
            </HorizontalStackLayout>

            <!-- OSM PBF row -->
            <HorizontalStackLayout Spacing="8">
                <Label Text="OSM PBF" VerticalOptions="Center" WidthRequest="80" />
                <Entry Text="{Binding OsmFilePath}" Placeholder="data/noordholland.osm.pbf" WidthRequest="300" />
                <Button Text="Browse" Clicked="OnBrowseOsm" Padding="8,4" />
                <Button Text="⬇" Command="{Binding DownloadOsmCommand}" Padding="8,4"
                        ToolTipProperties.Text="Download OSM extract" />
            </HorizontalStackLayout>

            <!-- Region Name -->
            <HorizontalStackLayout Spacing="8">
                <Label Text="Region" VerticalOptions="Center" WidthRequest="80" />
                <Entry Text="{Binding RegionName}" Placeholder="noordholland" WidthRequest="300" />
            </HorizontalStackLayout>

            <!-- Parse button -->
            <Button Text="Parse Data" Command="{Binding ParseCommand}" HorizontalOptions="Start" />

            <!-- Parsing activity indicator -->
            <HorizontalStackLayout Spacing="8" IsVisible="{Binding IsBusy}">
                <ActivityIndicator IsRunning="{Binding IsBusy}" WidthRequest="20" HeightRequest="20"
                                   VerticalOptions="Center" />
                <Label Text="Parsing…" VerticalOptions="Center" FontSize="12" TextColor="Gray" />
            </HorizontalStackLayout>

            <!-- ═══ Download Progress ═══ -->
            <VerticalStackLayout Spacing="4" IsVisible="{Binding IsDownloading}">
                <ProgressBar Progress="{Binding DownloadProgress01}" />
                <Label FontSize="12">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Downloading: " />
                            <Span Text="{Binding CurrentDownload.FileName}" FontAttributes="Bold" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </VerticalStackLayout>

            <!-- ═══ Summary ═══ -->
            <Label Text="{Binding Summary}" FontSize="14" FontAttributes="Italic" />
            <Label Text="{Binding CulledSummary}" FontSize="12" TextColor="Gray" />

            <!-- ═══ Map Canvas ═══ -->
            <Label Text="Map Preview" FontAttributes="Bold" FontSize="16" Margin="0,12,0,0" />

            <HorizontalStackLayout Spacing="12">
                <HorizontalStackLayout Spacing="4">
                    <CheckBox x:Name="ChkTowns" IsChecked="True" CheckedChanged="OnLayerToggle" />
                    <Label Text="Towns" VerticalOptions="Center" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="4">
                    <CheckBox x:Name="ChkRoads" IsChecked="True" CheckedChanged="OnLayerToggle" />
                    <Label Text="Roads" VerticalOptions="Center" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="4">
                    <CheckBox x:Name="ChkWater" IsChecked="True" CheckedChanged="OnLayerToggle" />
                    <Label Text="Water" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </HorizontalStackLayout>

            <GraphicsView x:Name="MapCanvas"
                          HeightRequest="400"
                          BackgroundColor="#1A1A2E">
                <GraphicsView.GestureRecognizers>
                    <PanGestureRecognizer PanUpdated="OnMapPan" />
                </GraphicsView.GestureRecognizers>
            </GraphicsView>

            <!-- ═══ Feature Lists ═══ -->
            <Label Text="Features" FontAttributes="Bold" FontSize="16" Margin="0,12,0,0" />

            <!-- Tab selector -->
            <HorizontalStackLayout Spacing="4">
                <Button x:Name="BtnTabTowns" Text="Towns" Clicked="OnFeatureTabTowns" Padding="10,4"
                        BackgroundColor="#512BD4" TextColor="White" />
                <Button x:Name="BtnTabRoads" Text="Roads" Clicked="OnFeatureTabRoads" Padding="10,4" />
                <Button x:Name="BtnTabWater" Text="Water" Clicked="OnFeatureTabWater" Padding="10,4" />
                <BoxView WidthRequest="20" Color="Transparent" />
                <Button Text="Auto-Cull…" Clicked="OnAutoCull" Padding="10,4" />
                <Button Text="Select All" Command="{Binding SelectAllCommand}" Padding="10,4" />
                <Button Text="Select None" Command="{Binding SelectNoneCommand}" Padding="10,4" />
            </HorizontalStackLayout>

            <!-- Search bar -->
            <Entry x:Name="SearchEntry" Placeholder="Search features…" TextChanged="OnSearchChanged" WidthRequest="300" HorizontalOptions="Start" />

            <!-- Town list -->
            <CollectionView x:Name="TownList"
                            ItemsSource="{Binding Towns}"
                            HeightRequest="250"
                            SelectionMode="Single"
                            SelectionChanged="OnTownSelected">
                <CollectionView.Header>
                    <Grid ColumnDefinitions="40,*,90,80,70,70" Padding="4,2" BackgroundColor="#2D2D3D">
                        <Label Grid.Column="0" Text="☑" FontAttributes="Bold" />
                        <Label Grid.Column="1" Text="Name" FontAttributes="Bold" />
                        <Label Grid.Column="2" Text="Category" FontAttributes="Bold" />
                        <Label Grid.Column="3" Text="Population" FontAttributes="Bold" />
                        <Label Grid.Column="4" Text="Lat" FontAttributes="Bold" />
                        <Label Grid.Column="5" Text="Lon" FontAttributes="Bold" />
                    </Grid>
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="wt:TownItem">
                        <Grid ColumnDefinitions="40,*,90,80,70,70" Padding="4,1">
                            <CheckBox Grid.Column="0" IsChecked="{Binding IsIncluded}" />
                            <Label Grid.Column="1" Text="{Binding Name}" VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="{Binding Category}" VerticalOptions="Center" />
                            <Label Grid.Column="3" Text="{Binding Population}" VerticalOptions="Center" />
                            <Label Grid.Column="4" Text="{Binding Lat, StringFormat='{0:F3}'}" VerticalOptions="Center" />
                            <Label Grid.Column="5" Text="{Binding Lon, StringFormat='{0:F3}'}" VerticalOptions="Center" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.Footer>
                    <Label x:Name="TownFooter" FontSize="12" TextColor="Gray" Padding="4,2" />
                </CollectionView.Footer>
            </CollectionView>

            <!-- Road list -->
            <CollectionView x:Name="RoadList"
                            ItemsSource="{Binding Roads}"
                            HeightRequest="250"
                            IsVisible="False"
                            SelectionMode="Single"
                            SelectionChanged="OnRoadSelected">
                <CollectionView.Header>
                    <Grid ColumnDefinitions="40,100,*,80,60" Padding="4,2" BackgroundColor="#2D2D3D">
                        <Label Grid.Column="0" Text="☑" FontAttributes="Bold" />
                        <Label Grid.Column="1" Text="Class" FontAttributes="Bold" />
                        <Label Grid.Column="2" Text="Near Town" FontAttributes="Bold" />
                        <Label Grid.Column="3" Text="Length km" FontAttributes="Bold" />
                        <Label Grid.Column="4" Text="Points" FontAttributes="Bold" />
                    </Grid>
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="wt:RoadItem">
                        <Grid ColumnDefinitions="40,100,*,80,60" Padding="4,1">
                            <CheckBox Grid.Column="0" IsChecked="{Binding IsIncluded}" />
                            <Label Grid.Column="1" Text="{Binding Classification}" VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="{Binding NearTown}" VerticalOptions="Center" />
                            <Label Grid.Column="3" Text="{Binding LengthKm, StringFormat='{0:F2}'}" VerticalOptions="Center" />
                            <Label Grid.Column="4" Text="{Binding PointCount}" VerticalOptions="Center" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.Footer>
                    <Label x:Name="RoadFooter" FontSize="12" TextColor="Gray" Padding="4,2" />
                </CollectionView.Footer>
            </CollectionView>

            <!-- Water list -->
            <CollectionView x:Name="WaterList"
                            ItemsSource="{Binding WaterBodies}"
                            HeightRequest="250"
                            IsVisible="False"
                            SelectionMode="Single"
                            SelectionChanged="OnWaterSelected">
                <CollectionView.Header>
                    <Grid ColumnDefinitions="40,*,80,80" Padding="4,2" BackgroundColor="#2D2D3D">
                        <Label Grid.Column="0" Text="☑" FontAttributes="Bold" />
                        <Label Grid.Column="1" Text="Name" FontAttributes="Bold" />
                        <Label Grid.Column="2" Text="Type" FontAttributes="Bold" />
                        <Label Grid.Column="3" Text="Area km²" FontAttributes="Bold" />
                    </Grid>
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="wt:WaterItem">
                        <Grid ColumnDefinitions="40,*,80,80" Padding="4,1">
                            <CheckBox Grid.Column="0" IsChecked="{Binding IsIncluded}" />
                            <Label Grid.Column="1" Text="{Binding Name}" VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="{Binding Type}" VerticalOptions="Center" />
                            <Label Grid.Column="3" Text="{Binding AreaKm2, StringFormat='{0:F3}'}" VerticalOptions="Center" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.Footer>
                    <Label x:Name="WaterFooter" FontSize="12" TextColor="Gray" Padding="4,2" />
                </CollectionView.Footer>
            </CollectionView>

            <!-- ═══ Build Section ═══ -->
            <Label Text="Build" FontAttributes="Bold" FontSize="16" Margin="0,12,0,0" />

            <HorizontalStackLayout Spacing="8">
                <Label Text="Output" VerticalOptions="Center" WidthRequest="80" />
                <Entry Text="{Binding OutputPath}" Placeholder="content/noordholland.RegionTemplateFile" WidthRequest="300" />
                <Button Text="Browse" Clicked="OnBrowseOutput" Padding="8,4" />
            </HorizontalStackLayout>

            <Button Text="Build RegionTemplate" Command="{Binding BuildCommand}" HorizontalOptions="Start" />

            <!-- Log area -->
            <Label Text="Log" FontAttributes="Bold" Margin="0,8,0,0" />
            <Frame BorderColor="Gray" Padding="8" HeightRequest="200">
                <ScrollView>
                    <Label Text="{Binding LogText}" FontFamily="Consolas" FontSize="12" />
                </ScrollView>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
