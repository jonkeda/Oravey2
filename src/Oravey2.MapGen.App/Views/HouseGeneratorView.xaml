<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Oravey2.MapGen.App.ViewModels"
             x:Class="Oravey2.MapGen.App.Views.HouseGeneratorView"
             x:DataType="vm:HouseGeneratorViewModel"
             Title="Houses">

    <ScrollView Padding="16">
        <VerticalStackLayout Spacing="10">

            <Label Text="Prompt" Style="{StaticResource SectionLabel}" />
            <Editor Text="{Binding Prompt}" Placeholder="Describe the building (e.g. a medieval stone house)" HeightRequest="80" />

            <Label Text="Image URL (optional)" Style="{StaticResource SectionLabel}" />
            <Entry Text="{Binding ImageUrl}" Placeholder="https://..." />

            <Label Text="Art Style" Style="{StaticResource SectionLabel}" />
            <Picker SelectedItem="{Binding ArtStyle}">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>realistic</x:String>
                        <x:String>cartoon</x:String>
                        <x:String>low-poly</x:String>
                        <x:String>sculpture</x:String>
                        <x:String>pbr</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>

            <HorizontalStackLayout Spacing="10">
                <Label Text="Remesh after generation" VerticalOptions="Center" />
                <Switch IsToggled="{Binding ShouldRemesh}" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10" IsVisible="{Binding ShouldRemesh}">
                <Label Text="Target polycount:" VerticalOptions="Center" />
                <Entry Text="{Binding TargetPolycount}" Keyboard="Numeric" WidthRequest="100" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10" Margin="0,10,0,0">
                <Button Text="Generate" Command="{Binding GenerateCommand}" Style="{StaticResource PrimaryButton}" />
                <Button Text="Cancel" Command="{Binding CancelCommand}" Style="{StaticResource DangerButton}" />
            </HorizontalStackLayout>

            <ActivityIndicator IsRunning="{Binding IsGenerating}" IsVisible="{Binding IsGenerating}" />

            <HorizontalStackLayout Spacing="16">
                <Image Source="{Binding PreviewThumbnail}"
                       WidthRequest="150" HeightRequest="150"
                       IsVisible="{Binding PreviewThumbnail, Converter={StaticResource IsNotNullConverter}}"
                       Aspect="AspectFit" />
                <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                    <Label Text="{Binding StatusMessage}" FontAttributes="Italic" />
                    <Label Text="{Binding Progress}" />
                </VerticalStackLayout>
            </HorizontalStackLayout>

            <Label Text="Log" Style="{StaticResource SectionLabel}" Margin="0,10,0,0" />
            <Border Style="{StaticResource LogFrame}" HeightRequest="200">
                <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                <ScrollView>
                    <Label Text="{Binding StreamingLog}" Style="{StaticResource MonospaceLabel}" />
                </ScrollView>
            </Border>

            <HorizontalStackLayout Spacing="10">
                <Button Text="Download GLB" Command="{Binding DownloadGlbCommand}" Style="{StaticResource SecondaryButton}" />
                <Button Text="Download FBX" Command="{Binding DownloadFbxCommand}" Style="{StaticResource SecondaryButton}" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
