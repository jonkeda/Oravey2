<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Oravey2.MapGen.App.ViewModels"
             x:Class="Oravey2.MapGen.App.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             Title="Settings">

    <ScrollView Padding="16">
        <VerticalStackLayout Spacing="10">

            <Label Text="Model" Style="{StaticResource SectionLabel}" />
            <Picker ItemsSource="{Binding AvailableModels}" SelectedItem="{Binding SelectedModel}" />

            <BoxView HeightRequest="1" Color="{StaticResource Outline}" Margin="0,10" />

            <Label Text="Bring Your Own Key (BYOK)" Style="{StaticResource SectionLabel}" />
            <HorizontalStackLayout Spacing="10">
                <Label Text="Enable BYOK" VerticalOptions="Center" />
                <Switch IsToggled="{Binding UseBYOK}" />
            </HorizontalStackLayout>

            <Label Text="Provider" />
            <Picker SelectedItem="{Binding ProviderType}" IsEnabled="{Binding UseBYOK}">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>openai</x:String>
                        <x:String>azure</x:String>
                        <x:String>anthropic</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>

            <Label Text="Base URL" />
            <Entry Text="{Binding BaseUrl}" Placeholder="https://api.openai.com/v1" IsEnabled="{Binding UseBYOK}" />

            <Label Text="API Key" />
            <Entry Text="{Binding ApiKey}" IsPassword="True" Placeholder="sk-..." IsEnabled="{Binding UseBYOK}" />

            <BoxView HeightRequest="1" Color="{StaticResource Outline}" Margin="0,10" />

            <Label Text="Export Path" Style="{StaticResource SectionLabel}" />
            <HorizontalStackLayout Spacing="10">
                <Entry Text="{Binding ExportPath}" Placeholder="Blueprints export folder" WidthRequest="400" />
                <Button Text="Browse..." Command="{Binding BrowseExportPathCommand}" />
            </HorizontalStackLayout>

            <Label Text="Content Pack Path" Style="{StaticResource SectionLabel}" Margin="0,10,0,0" />
            <HorizontalStackLayout Spacing="10">
                <Entry Text="{Binding ContentPackPath}" Placeholder="Root folder of a content pack (contains manifest.json)" WidthRequest="400" />
                <Button Text="Browse..." Command="{Binding BrowseContentPackPathCommand}" />
            </HorizontalStackLayout>

            <Label Text="Data Root (regions folder)" Style="{StaticResource SectionLabel}" Margin="0,10,0,0" />
            <Label Text="Leave blank to use default AppData location. Requires restart." Style="{StaticResource CaptionLabel}" />
            <HorizontalStackLayout Spacing="10">
                <Entry Text="{Binding DataRoot}" Placeholder="e.g. E:\repos\Private\Oravey2\data" WidthRequest="400" />
                <Button Text="Browse..." Command="{Binding BrowseDataRootCommand}" />
            </HorizontalStackLayout>

            <BoxView HeightRequest="1" Color="{StaticResource Outline}" Margin="0,10" />

            <Label Text="Copilot CLI Path (optional)" Style="{StaticResource SectionLabel}" />
            <Entry Text="{Binding CliPath}" Placeholder="Auto-detect" />

            <BoxView HeightRequest="1" Color="{StaticResource Outline}" Margin="0,10" />

            <Label Text="NASA Earthdata (SRTM Downloads)" Style="{StaticResource SectionLabel}" FontSize="16" />

            <Label Text="Username" />
            <Entry Text="{Binding EarthdataUsername}" Placeholder="Earthdata username" />

            <Label Text="Password" />
            <Entry Text="{Binding EarthdataPassword}" IsPassword="True" Placeholder="Earthdata password" />

            <BoxView HeightRequest="1" Color="{StaticResource Outline}" Margin="0,10" />

            <Label Text="Meshy AI" Style="{StaticResource SectionLabel}" FontSize="16" />

            <Label Text="Meshy API Key" />
            <Entry Text="{Binding MeshyApiKey}" IsPassword="True" Placeholder="Paste your Meshy API key" />

            <Label Text="Model Export Path" />
            <Entry Text="{Binding MeshyExportPath}" Placeholder="Folder for downloaded 3D models" />

            <Label Text="Default Art Style" />
            <Picker SelectedItem="{Binding MeshyDefaultArtStyle}">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>realistic</x:String>
                        <x:String>cartoon</x:String>
                        <x:String>low-poly</x:String>
                        <x:String>sculpture</x:String>
                        <x:String>pbr</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>

            <HorizontalStackLayout Spacing="10" Margin="0,20,0,0">
                <Button Text="Save Settings" Command="{Binding SaveSettingsCommand}" Style="{StaticResource PrimaryButton}" />
                <Button Text="Test Connection" Command="{Binding TestConnectionCommand}" Style="{StaticResource SecondaryButton}" />
                <Button Text="Login to GitHub" Command="{Binding LoginCopilotCommand}" Style="{StaticResource SecondaryButton}" />
            </HorizontalStackLayout>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

            <Label Text="{Binding StatusMessage}" FontAttributes="Italic" TextColor="{StaticResource OnSurfaceVariant}" Margin="0,10,0,0" />

            <Button Text="Install GitHub Copilot (winget)" 
                    Command="{Binding InstallCopilotCommand}" 
                    IsVisible="{Binding ShowInstallCopilot}"
                    Style="{StaticResource SuccessButton}"
                    Margin="0,5,0,0" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
