<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Oravey2.MapGen.App.ViewModels"
             x:Class="Oravey2.MapGen.App.Views.PipelineWizardView"
             x:DataType="vm:PipelineWizardViewModel"
             Title="Pipeline v3">

    <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2" Padding="16,8" BackgroundColor="{StaticResource Background}"
              ColumnDefinitions="*,Auto">
            <Label Text="Generation Pipeline v3" FontSize="20" FontAttributes="Bold"
                    VerticalOptions="Center" />
            <Button Grid.Column="1" Text="⚙ Settings" Command="{Binding OpenSettingsCommand}"
                    Style="{StaticResource GhostButton}" TextColor="{StaticResource OnSurfaceVariant}" FontSize="14" />
        </Grid>

        <!-- Sidebar step list -->
        <CollectionView Grid.Row="1" Grid.Column="0" ItemsSource="{Binding Steps}"
                        SelectionMode="Single" BackgroundColor="{StaticResource SurfaceVariant}" Margin="0">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:PipelineStepInfo">
                    <Grid Padding="12,10" ColumnDefinitions="*,Auto"
                          AutomationId="{Binding AutomationId}">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:PipelineWizardViewModel}}, Path=NavigateToStepCommand}"
                                CommandParameter="{Binding}" />
                        </Grid.GestureRecognizers>

                        <Label Text="{Binding DisplayText}" FontSize="14"
                               TextColor="{Binding IsCurrent, Converter={StaticResource BoolToColorConverter}}"
                               VerticalOptions="Center" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Main content area -->
        <ContentView Grid.Row="1" Grid.Column="1" Content="{Binding CurrentStepView}"
                     AutomationId="WizardStepContent" Padding="16" />

        <!-- IsBusy sentinel for Brinell.Maui test synchronization -->
        <Label Grid.Row="2" Grid.Column="1" AutomationId="UITest_IsBusy"
               Text="{Binding IsBusy}" HeightRequest="1" WidthRequest="1" Opacity="0.01" />

        <!-- Status bar -->
        <Label Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding StatusMessage}"
               Padding="16,8" FontSize="12" TextColor="{StaticResource OnSurfaceVariant}" BackgroundColor="{StaticResource Background}" />
    </Grid>

</ContentPage>
